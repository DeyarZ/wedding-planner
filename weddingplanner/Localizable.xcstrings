    "✉️ Time to send those invitations! Most go out 2-3 months before." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "✉️ Zeit für die Einladungen! Meist 2–3 Monate vorher verschickt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "✉️ ¡Hora de enviar invitaciones! Suelen mandarse 2-3 meses antes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "✉️ Il est temps d'envoyer les invitations ! Souvent 2 à 3 mois avant."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "✉️ È ora di inviare gli inviti! Di solito 2-3 mesi prima."
          }
        }
      }
    },
    "🌟 You're doing amazing! Over 70% of your tasks are complete." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🌟 Du machst das großartig! Über 70 % deiner Aufgaben sind erledigt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🌟 ¡Lo estás haciendo genial! Más del 70 % de tus tareas están listas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🌟 Vous gérez à merveille ! Plus de 70 % de vos tâches sont faites."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🌟 Stai andando alla grande! Oltre il 70% delle attività è completato."
          }
        }
      }
    },
    "💝 You have a few tasks that need attention. Take them one at a time - you've got this!" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "💝 Ein paar Aufgaben brauchen Aufmerksamkeit. Eine nach der anderen – du schaffst das!"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "💝 Tienes algunas tareas pendientes. Una a una, ¡tú puedes!"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "💝 Quelques tâches demandent votre attention. Une à la fois, vous y arrivez !"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "💝 Hai alcune attività in sospeso. Una alla volta, ce la fai!"
          }
        }
      }
    },
    "📷 Most couples book their photographer 6-8 months out. Ready to start looking?" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📷 Die meisten Paare buchen ihre Fotograf:innen 6–8 Monate vorher. Bereit zu suchen?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📷 La mayoría reserva fotógrafo 6-8 meses antes. ¿Empezamos a buscar?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📷 La plupart réservent leur photographe 6 à 8 mois avant. On commence à chercher ?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📷 La maggior parte prenota il fotografo 6-8 mesi prima. Iniziamo a cercare?"
          }
        }
      }
