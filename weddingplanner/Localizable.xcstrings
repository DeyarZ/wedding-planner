          "stringUnit" : {
            "state" : "translated",
            "value" : "Premium-Funktionen erfordern ein Abo. Abos verlängern sich automatisch, sofern nicht mind. 24 Stunden vor Periodenende gekündigt wird. Du kannst jederzeit über deine App-Store-Einstellungen kündigen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las funciones premium requieren suscripción. Se renueva automáticamente salvo cancelación 24 h antes del fin del periodo. Puedes cancelar en los ajustes de App Store."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les fonctions premium nécessitent un abonnement. Il se renouvelle automatiquement sauf annulation 24 h avant la fin de la période. Vous pouvez annuler via les réglages de l'App Store."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le funzioni premium richiedono un abbonamento. Si rinnova automaticamente salvo disdetta 24 ore prima della fine del periodo. Puoi annullare dalle impostazioni dell'App Store."
          }
        }
      }
