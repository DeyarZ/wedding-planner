    "Wedding Planner is a mobile application that helps users plan and organize their wedding events. The app provides tools for vendor management, budget tracking, timeline creation, and other wedding-related planning features." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wedding Planner ist eine App, die bei der Planung und Organisation der Hochzeit hilft. Sie bietet Tools für Dienstleister, Budget, Zeitplan und weitere Planungsfunktionen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wedding Planner es una app que ayuda a planificar y organizar la boda. Ofrece herramientas para proveedores, presupuesto, cronograma y más."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wedding Planner est une app qui aide à planifier et organiser le mariage. Elle propose des outils pour les prestataires, le budget, le programme et plus."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wedding Planner è un'app che aiuta a pianificare e organizzare il matrimonio. Offre strumenti per fornitori, budget, programma e altro."
          }
        }
      }
    },
