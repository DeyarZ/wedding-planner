        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Planifica la boda de tus sueños con facilidad. Del presupuesto a los invitados, te guiamos en cada momento mágico."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Organisez le mariage de vos rêves en toute simplicité. Du budget aux invités, nous vous guidons à chaque instant magique."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pianifica il matrimonio dei tuoi sogni con facilità. Dal budget agli ospiti, ti guidiamo in ogni momento magico."
