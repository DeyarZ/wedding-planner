    },
    "Plan your dream wedding with ease. From budget tracking to guest management, we'll guide you through every magical moment." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plane deine Traumhochzeit mit Leichtigkeit. Vom Budget bis zur Gästeliste begleiten wir dich durch jeden magischen Moment."
